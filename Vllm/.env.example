# =============================================================================
# .env.example — Copy to .env and adjust for your environment
# =============================================================================

# --- Model ---
VLLM_MODEL=Qwen/Qwen3.5-9B
MODEL_LOCAL_PATH=./models/Qwen3.5-9B
USE_LOCAL_MODEL=true            # true = load from MODEL_LOCAL_PATH; false = HuggingFace hub

# --- vLLM Server (started separately via launch_vllm.sh) ---
VLLM_SERVER_URL=http://localhost:8000/v1
VLLM_API_KEY=not-needed         # vLLM does not require a real key by default

# --- vLLM serve parameters (used by launch_vllm.sh) ---
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.85     # fraction of GPU VRAM (0.0–1.0)
TENSOR_PARALLEL_SIZE=1          # set to 2+ for multi-GPU
VLLM_DTYPE=auto                 # auto | float16 | bfloat16
ENFORCE_EAGER=false

# --- Inference ---
TEMPERATURE=0.05                # keep low for deterministic validation
MAX_NEW_TOKENS=2048
TOP_P=0.9

# --- FastAPI Service ---
HOST=0.0.0.0
PORT=8001

# --- Validation ---
MAX_FILE_SIZE_MB=20

# --- Logging ---
LOG_LEVEL=INFO
